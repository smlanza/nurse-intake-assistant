# Stable, non-secret inputs for the disposable daily Azure environment.
# Copy to .env.daily-azure.local and replace every angle-bracket placeholder.

AZURE_SUBSCRIPTION_NAME=<subscription-name>
AZURE_LOCATION=eastus2
AZURE_RESOURCE_GROUP=<daily-resource-group-name>

AZURE_ENVIRONMENT_NAME=daily
# Existing Bicep parameter used as the short resource-name prefix.
AZURE_PROJECT_NAME=nurse-intake

# Stable operator-selected base; proven global conflicts get a bounded runtime suffix.
AZURE_FOUNDRY_ACCOUNT_NAME=<foundry-account-base-name>
AZURE_FOUNDRY_PROJECT_NAME=fictional-intake-project
AZURE_FOUNDRY_MODEL_DEPLOYMENT_NAME=nurse-intake-gpt-5-mini
AZURE_FOUNDRY_MODEL_NAME=gpt-5-mini
AZURE_FOUNDRY_MODEL_VERSION=2025-08-07
AZURE_FOUNDRY_MODEL_SKU=GlobalStandard
AZURE_FOUNDRY_MODEL_CAPACITY=1
AZURE_FOUNDRY_AGENT_NAME=nurse-intake-agent

AZURE_WEB_APP_NAME=<globally-unique-web-app-name>
AZURE_WEB_APP_SKU=B1

ENABLE_HOSTED_FOUNDRY_VERIFIER=true
DISCOVER_HOSTED_FOUNDRY_WEBJOB=true
