# Manual Azure AI Foundry Agent smoke-test settings.
# Copy to .env.foundry-agent.local for local use. Do not commit real values.

AGENT_PROVIDER=foundry-agent
AZURE_AI_FOUNDRY_MODEL_DEPLOYMENT_NAME=
# Uses the project-responses agent name/version path.
AZURE_AI_FOUNDRY_AGENT_PROJECT_ENDPOINT=<your-foundry-agent-project-endpoint>
AZURE_AI_FOUNDRY_AGENT_NAME=<your-foundry-agent-name>
AZURE_AI_FOUNDRY_AGENT_VERSION=<your-foundry-agent-version>
# Required only for --publish-foundry-evaluation; these are scope identifiers.
AZURE_SUBSCRIPTION_ID=<your-azure-subscription-id>
AZURE_AI_FOUNDRY_RESOURCE_GROUP_NAME=<your-foundry-resource-group-name>
AZURE_AI_FOUNDRY_PROJECT_NAME=<your-foundry-project-name>

# Keep the default demo and unrelated providers mock/offline.
APP_MODE=mock
AI_PROVIDER=mock
EMAIL_PROVIDER=mock
SMS_PROVIDER=mock
SPEECH_PROVIDER=mock
