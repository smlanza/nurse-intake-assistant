# Manual Azure AI Foundry Agent smoke-test settings.
# Copy to .env.foundry-agent.local for local use. Do not commit real values.

AGENT_PROVIDER=foundry-agent
AZURE_AI_FOUNDRY_MODEL_DEPLOYMENT_NAME=
# Project endpoint is used for provisioning and read-only metadata verification.
AZURE_AI_FOUNDRY_AGENT_PROJECT_ENDPOINT=<your-foundry-agent-project-endpoint>
# Preferred complete stable OpenAI protocol base from the current agent object.
AZURE_AI_FOUNDRY_AGENT_ENDPOINT=<your-stable-agent-openai-protocol-endpoint>
AZURE_AI_FOUNDRY_AGENT_NAME=<your-foundry-agent-name>
AZURE_AI_FOUNDRY_AGENT_VERSION=<your-foundry-agent-version>
# Leave false for the stable endpoint path. Set true only for intentional legacy
# project-endpoint compatibility when AZURE_AI_FOUNDRY_AGENT_ENDPOINT is blank.
AZURE_AI_FOUNDRY_AGENT_USE_PROJECT_ENDPOINT_COMPATIBILITY=false
# Optional user-assigned managed identity identifier. Leave blank for local
# development or a system-assigned managed identity.
AZURE_AI_FOUNDRY_MANAGED_IDENTITY_CLIENT_ID=<optional-user-assigned-managed-identity-client-id>
# Required only for --publish-foundry-evaluation; these are scope identifiers.
AZURE_SUBSCRIPTION_ID=<your-azure-subscription-id>
AZURE_AI_FOUNDRY_RESOURCE_GROUP_NAME=<your-foundry-resource-group-name>
AZURE_AI_FOUNDRY_PROJECT_NAME=<your-foundry-project-name>

# Keep the default demo and unrelated providers mock/offline.
APP_MODE=mock
AI_PROVIDER=mock
EMAIL_PROVIDER=mock
SMS_PROVIDER=mock
SPEECH_PROVIDER=mock
DEMO_SUPPRESS_NOTIFICATIONS=true
