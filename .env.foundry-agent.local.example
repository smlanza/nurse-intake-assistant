# Manual Azure AI Foundry Agent smoke-test settings.
# Copy to .env.foundry-agent.local for local use. Do not commit real values.

AGENT_PROVIDER=foundry-agent
AZURE_AI_FOUNDRY_AGENT_PROJECT_ENDPOINT=<your-foundry-agent-project-endpoint>
AZURE_AI_FOUNDRY_AGENT_ID=<your-foundry-agent-id>

# Keep the default demo and unrelated providers mock/offline.
APP_MODE=mock
AI_PROVIDER=mock
EMAIL_PROVIDER=mock
SMS_PROVIDER=mock
SPEECH_PROVIDER=mock
