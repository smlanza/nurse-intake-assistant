# Manual Azure AI Foundry smoke-test settings.
# Copy to .env.foundry.local for local use. Do not commit real values.

AI_PROVIDER=foundry
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=https://your-foundry-project-endpoint.example.invalid
AZURE_AI_FOUNDRY_MODEL_DEPLOYMENT_NAME=your-model-deployment-name

# Keep notifications controlled unless explicitly testing them separately.
EMAIL_PROVIDER=mock
SMS_PROVIDER=mock
