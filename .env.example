APP_BASE_URL=http://localhost:8000

APP_MODE=mock

# AI_PROVIDER=mock is the safe local default. It uses deterministic extraction
# and does not call Azure AI services.
AI_PROVIDER=mock
EMAIL_PROVIDER=mock
# SMS_PROVIDER=mock is the safe local default. Mock SMS notifications are
# recorded in memory for local/demo inspection and do not send real SMS.
SMS_PROVIDER=mock
# SPEECH_PROVIDER=mock is the safe local default. The current voicemail route
# accepts already-transcribed text and does not call Azure Speech.
SPEECH_PROVIDER=mock
# AGENT_PROVIDER=mock is the safe local default. Foundry Agent orchestration is
# not wired into the local request-processing pipeline.
AGENT_PROVIDER=mock

# Cosmos settings are only required when running with APP_MODE=cosmos.
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE_NAME=nurse-intake
COSMOS_CONTAINER_NAME=cases

# ACS Email settings are only required when running with EMAIL_PROVIDER=acs.
# Do not commit real ACS connection strings or secrets.
ACS_EMAIL_CONNECTION_STRING=
ACS_EMAIL_SENDER_ADDRESS=
NURSE_NOTIFICATION_EMAIL=

# ACS SMS settings are only required when running with SMS_PROVIDER=acs.
# ACS SMS is integrated to the SDK/send-request path, but handset delivery
# requires toll-free verification and has not been confirmed yet.
# Do not commit real ACS connection strings, access keys, or phone numbers.
ACS_SMS_CONNECTION_STRING=
ACS_SMS_FROM_PHONE_NUMBER=
NURSE_NOTIFICATION_PHONE_NUMBER=

# Future Azure AI Foundry mode will use AI_PROVIDER=foundry.
# Live Azure AI Foundry calls are not enabled in local mock mode.
# Do not commit Azure AI keys, real endpoints, or model deployment names.
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=
AZURE_AI_FOUNDRY_MODEL_DEPLOYMENT_NAME=

# Future Azure AI Foundry Agent mode will use AGENT_PROVIDER=foundry-agent.
# Manual smoke validation uses the portal-supported agent name/version path.
# Do not commit real project endpoints, agent IDs/names/versions, credentials, or PHI.
AZURE_AI_FOUNDRY_AGENT_PROJECT_ENDPOINT=
AZURE_AI_FOUNDRY_AGENT_ID=
AZURE_AI_FOUNDRY_AGENT_NAME=
AZURE_AI_FOUNDRY_AGENT_VERSION=

# Future Azure Speech mode will use SPEECH_PROVIDER=azure.
# Live Azure Speech transcription/audio processing is deferred.
# Do not commit real endpoints, regions tied to production resources, or keys.
AZURE_SPEECH_ENDPOINT=
AZURE_SPEECH_REGION=

# Current notification suppression flag for both email and SMS.
DEMO_SUPPRESS_NOTIFICATIONS=false
