APP_MODE=mock
APP_BASE_URL=http://localhost:8000

EMAIL_PROVIDER=mock

# ACS Email settings are only required when running with EMAIL_PROVIDER=acs.
# Do not commit real ACS connection strings or secrets.
ACS_EMAIL_CONNECTION_STRING=
ACS_EMAIL_SENDER_ADDRESS=
NURSE_NOTIFICATION_EMAIL=

# Cosmos settings are only required when running with APP_MODE=cosmos.
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE_NAME=nurse-intake
COSMOS_CONTAINER_NAME=cases

DEMO_SUPPRESS_SMS=true
